[Unit]
Description=J.A.R.V.I.S. HTTP/WebSocket API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=jarvis
Group=jarvis
WorkingDirectory=/opt/jarvis
EnvironmentFile=/opt/jarvis/.env
ExecStart=/opt/jarvis/.venv/bin/python -m jarvis.api
Restart=on-failure
RestartSec=5

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/opt/jarvis/data /opt/jarvis/logs

[Install]
WantedBy=multi-user.target
