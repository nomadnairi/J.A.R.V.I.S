# ============================================
#  J.A.R.V.I.S. Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LLM Providers ---
# At least one API key is required.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=

# Which provider/model the core engine uses.
# Options: anthropic | openai
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514
# Custom OpenAI-compatible endpoint. For OpenRouter set:
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=sk-or-...              (your OpenRouter key)
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   LLM_MODEL=anthropic/claude-3.7-sonnet (any OpenRouter model slug)
OPENAI_BASE_URL=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# Agentic tool-calling: max tool rounds per turn, and max in-memory sessions.
MAX_TOOL_ROUNDS=5
MAX_SESSIONS=1000

# --- Security (dangerous capabilities are OFF by default) ---
# Root directory that file/coding tools are sandboxed to.
WORKSPACE_ROOT=.
ALLOW_FILE_READ=true
ALLOW_FILE_WRITE=false
ALLOW_SHELL=false
ALLOW_DESKTOP_CONTROL=false
AUDIT_LOG_PATH=logs/audit.log
# Capability toggles (tools are registered but stay gated by the ALLOW_* flags above).
FILES_ENABLED=true
CODING_ENABLED=true
DESKTOP_ENABLED=true
AGENTS_ENABLED=true

# --- Goals ---
GOALS_ENABLED=true

# --- Integrations ---
INTEGRATIONS_ENABLED=true
# Weather (Open-Meteo, free, no key required)
WEATHER_ENABLED=true
# Home Assistant (smart home) — set both to enable device control
HOMEASSISTANT_URL=
HOMEASSISTANT_TOKEN=

# --- Assistant persona ---
ASSISTANT_NAME=J.A.R.V.I.S.
USER_NAME=Sir

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_FILE=logs/jarvis.log

# --- Data / storage ---
DATABASE_URL=sqlite:///data/jarvis.db
REDIS_URL=redis://localhost:6379/0
VECTOR_STORE_PATH=chroma_db

# --- Memory ---
MEMORY_ENABLED=true
# Vector backend: sqlite (default, persistent) | memory | chroma
MEMORY_BACKEND=sqlite
# Embedding backend: hashing (offline) | local (semantic, needs fastembed) | openai
EMBEDDING_BACKEND=hashing
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
MEMORY_RECALL_LIMIT=4
# Minimum similarity to recall a memory, and recency vs. similarity weight.
MEMORY_MIN_SCORE=0.15
MEMORY_RECENCY_WEIGHT=0.15
# Extract durable facts via the LLM instead of storing raw transcripts.
MEMORY_FACT_EXTRACTION=true
# Cap of memories kept per session (0 = unlimited); dedup similarity threshold.
MEMORY_MAX_PER_SESSION=200
MEMORY_DEDUP_THRESHOLD=0.95
# Redact secrets (tokens, API keys, card numbers) before storing memory.
MEMORY_REDACT_SECRETS=true
MEMORY_DB_PATH=data/jarvis.db
MEMORY_VECTOR_PATH=data/memory.json

# --- Voice (pluggable STT / TTS) ---
VOICE_ENABLED=true
# STT: openai (Whisper API, paid, needs OPENAI_API_KEY) | local (free/offline, needs openai-whisper)
STT_BACKEND=openai
# TTS: openai (paid) | edge (free, needs edge-tts) | gtts (free, needs gTTS)
TTS_BACKEND=openai
# OpenAI STT/TTS settings (used when the corresponding backend is "openai").
STT_MODEL=whisper-1
TTS_MODEL=tts-1
TTS_VOICE=alloy
# Local Whisper model size when STT_BACKEND=local: tiny | base | small | medium | large
LOCAL_WHISPER_MODEL=base
# Whether the bot also sends a spoken reply back.
VOICE_REPLIES=true

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000
# Bearer / X-API-Key required to call the API. Leave empty ONLY for local dev.
API_KEY=

# --- Accounts & licensing (per-user login for the desktop/mobile clients) ---
# Enable username/password accounts + license checks on the API.
AUTH_ENABLED=false
AUTH_DB_PATH=data/auth.db
# Admin key for /admin/* endpoints (create accounts, issue licenses).
# Empty disables the admin API entirely (use the jarvis-admin CLI instead).
AUTH_ADMIN_KEY=
# Login token lifetime, hours (720 = 30 days).
AUTH_TOKEN_TTL_HOURS=720
# Require a linked & verified Telegram account before login succeeds.
AUTH_REQUIRE_TELEGRAM=false

# --- Billing (payments -> automatic license issuance) ---
# Enables /buy in the bot (Telegram Stars) and POST /billing/webhook.
BILLING_ENABLED=false
# Price in Telegram Stars (XTR).
BILLING_PRICE_STARS=2500
BILLING_PLAN=standard
# License validity in days (0 = perpetual).
BILLING_PLAN_DAYS=365
# HMAC-SHA256 secret for the external-payments webhook (empty = disabled).
BILLING_WEBHOOK_SECRET=

# --- Telegram bot ---
# Get a token from @BotFather. Never commit your real token — keep it here in
# your local .env only.
TELEGRAM_BOT_TOKEN=
# Optional: restrict access to specific Telegram user IDs (comma-separated).
# Leave empty to allow everyone.
TELEGRAM_ALLOWED_USERS=
# Telegram user IDs with access to the bot's owner admin panel (/admin).
# Find your ID via @userinfobot. Comma-separated.
TELEGRAM_ADMIN_USERS=
# Allow the assistant to SEND Telegram messages/posts as a tool (outbound).
TELEGRAM_SEND_ENABLED=false
# Default channel (@channelusername or chat id) for the telegram_post tool.
TELEGRAM_CHANNEL=
