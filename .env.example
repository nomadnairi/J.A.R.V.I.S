# ============================================
#  J.A.R.V.I.S. Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LLM Providers ---
# At least one API key is required.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=

# Which provider/model the core engine uses.
# Options: anthropic | openai
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# Agentic tool-calling: max tool rounds per turn, and max in-memory sessions.
MAX_TOOL_ROUNDS=5
MAX_SESSIONS=1000

# --- Assistant persona ---
ASSISTANT_NAME=J.A.R.V.I.S.
USER_NAME=Sir

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_FILE=logs/jarvis.log

# --- Data / storage (used from Stage 2 onward) ---
DATABASE_URL=sqlite:///data/jarvis.db
REDIS_URL=redis://localhost:6379/0
VECTOR_STORE_PATH=chroma_db

# --- Voice (used from Stage 3 onward) ---
SPEECH_RECOGNITION_ENGINE=whisper
TEXT_TO_SPEECH_ENGINE=gtts
VOICE_LANGUAGE=en-US
