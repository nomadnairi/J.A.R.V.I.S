# ============================================
#  J.A.R.V.I.S. Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LLM Providers ---
# Three independent providers. Configure only the one(s) you want — no mixing.
# Pick the engine's default with LLM_PROVIDER: anthropic | openai | openrouter
LLM_PROVIDER=anthropic

# 1) Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Model used when LLM_PROVIDER=anthropic.
LLM_MODEL=claude-sonnet-4-20250514

# 2) OpenAI (ChatGPT) — the real OpenAI only.
OPENAI_API_KEY=
# Leave empty for the official API. (Only change for an OpenAI-compatible proxy;
# do NOT put OpenRouter here — OpenRouter has its own settings below.)
OPENAI_BASE_URL=

# 3) OpenRouter — a separate gateway to many models (GPT, Claude, Gemini, …).
#    To use ONLY OpenRouter, just set:
#       LLM_PROVIDER=openrouter
#       OPENROUTER_API_KEY=sk-or-...
#       OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free  (any OR slug)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.7-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# 4) Local / self-hosted models (Ollama, LM Studio, vLLM, llama.cpp).
#    All speak the OpenAI-compatible API, so just pick a backend preset:
#       LLM_PROVIDER=local
#       LOCAL_LLM_BACKEND=ollama        # ollama | lmstudio | vllm | llamacpp | custom
#       LOCAL_LLM_MODEL=llama3          # the model name your server serves
#    Backend presets (used unless LOCAL_LLM_BASE_URL is set):
#       ollama   -> http://localhost:11434/v1
#       lmstudio -> http://localhost:1234/v1
#       vllm     -> http://localhost:8000/v1
#       llamacpp -> http://localhost:8080/v1
LOCAL_LLM_BACKEND=ollama
LOCAL_LLM_MODEL=llama3
# Override the preset endpoint (required for LOCAL_LLM_BACKEND=custom).
LOCAL_LLM_BASE_URL=
# Most local servers ignore auth; set only if yours requires a token.
LOCAL_LLM_API_KEY=

# Multi-AI switching in the bot: whichever of the providers above are configured
# become switchable profiles (claude = Anthropic, gpt = OpenAI,
# openrouter = OpenRouter, local = your self-hosted model).

LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# Agentic tool-calling: max tool rounds per turn, and max in-memory sessions.
MAX_TOOL_ROUNDS=5
MAX_SESSIONS=1000

# --- Security (dangerous capabilities are OFF by default) ---
# Root directory that file/coding tools are sandboxed to.
WORKSPACE_ROOT=.
ALLOW_FILE_READ=true
ALLOW_FILE_WRITE=false
ALLOW_SHELL=false
ALLOW_DESKTOP_CONTROL=false
AUDIT_LOG_PATH=logs/audit.log
# Capability toggles (tools are registered but stay gated by the ALLOW_* flags above).
FILES_ENABLED=true
CODING_ENABLED=true
DESKTOP_ENABLED=true
AGENTS_ENABLED=true

# --- Goals ---
GOALS_ENABLED=true

# --- Integrations ---
INTEGRATIONS_ENABLED=true
# Weather (Open-Meteo, free, no key required)
WEATHER_ENABLED=true
# City for the desktop dashboard's live weather panel (empty = no weather).
WEATHER_CITY=
# Home Assistant (smart home) — set both to enable device control
HOMEASSISTANT_URL=
HOMEASSISTANT_TOKEN=

# --- MCP (Model Context Protocol) ---
# Mount tools from external MCP servers (the agentskills.io / Hermes / Claude
# standard) as native skills the assistant can call. Point at a JSON file with
# the standard {"mcpServers": {...}} shape, or paste the JSON inline.
#   MCP_CONFIG_PATH=/path/to/mcp.json
#   or MCP_SERVERS={"mcpServers":{"fs":{"command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/data"]}}}
# Requires the 'mcp' package: pip install mcp
MCP_ENABLED=false
MCP_CONFIG_PATH=
MCP_SERVERS=

# --- Assistant persona ---
# The assistant's name. White-label: rename it to anything you sell it as.
ASSISTANT_NAME=KER
# Extra names it also answers to (comma-separated), e.g. a personal wake-word.
# Leave blank for resold copies; set e.g. Jarvis for your own build.
ASSISTANT_ALIASES=
USER_NAME=Sir

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_FILE=logs/jarvis.log

# --- Data / storage ---
DATABASE_URL=sqlite:///data/jarvis.db
REDIS_URL=redis://localhost:6379/0
VECTOR_STORE_PATH=chroma_db

# --- Memory ---
MEMORY_ENABLED=true
# Vector backend: sqlite (default, persistent) | memory | chroma
MEMORY_BACKEND=sqlite
# Embedding backend: hashing (offline) | local (semantic, needs fastembed) | openai
EMBEDDING_BACKEND=hashing
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
MEMORY_RECALL_LIMIT=4
# Minimum similarity to recall a memory, and recency vs. similarity weight.
MEMORY_MIN_SCORE=0.15
MEMORY_RECENCY_WEIGHT=0.15
# Extract durable facts via the LLM instead of storing raw transcripts.
MEMORY_FACT_EXTRACTION=true
# Cap of memories kept per session (0 = unlimited); dedup similarity threshold.
MEMORY_MAX_PER_SESSION=200
MEMORY_DEDUP_THRESHOLD=0.95
# Redact secrets (tokens, API keys, card numbers) before storing memory.
MEMORY_REDACT_SECRETS=true
MEMORY_DB_PATH=data/jarvis.db
MEMORY_VECTOR_PATH=data/memory.json

# --- Voice (pluggable STT / TTS) ---
VOICE_ENABLED=true
# STT: openai (Whisper API, paid, needs OPENAI_API_KEY) | local (free/offline, needs openai-whisper)
STT_BACKEND=openai
# TTS: openai (paid) | edge (free, needs edge-tts) | gtts (free, needs gTTS)
TTS_BACKEND=openai
# OpenAI STT/TTS settings (used when the corresponding backend is "openai").
STT_MODEL=whisper-1
TTS_MODEL=tts-1
TTS_VOICE=alloy
# Local Whisper model size when STT_BACKEND=local: tiny | base | small | medium | large
LOCAL_WHISPER_MODEL=base
# Whether the bot also sends a spoken reply back.
VOICE_REPLIES=true

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000
# Bearer / X-API-Key required to call the API. Leave empty ONLY for local dev.
API_KEY=

# --- Accounts & licensing (per-user login for the desktop/mobile clients) ---
# Enable username/password accounts + license checks on the API.
AUTH_ENABLED=false
AUTH_DB_PATH=data/auth.db
# Admin key for /admin/* endpoints (create accounts, issue licenses).
# Empty disables the admin API entirely (use the jarvis-admin CLI instead).
AUTH_ADMIN_KEY=
# Login token lifetime, hours (720 = 30 days).
AUTH_TOKEN_TTL_HOURS=720
# Require a linked & verified Telegram account before login succeeds.
AUTH_REQUIRE_TELEGRAM=false

# --- Billing (payments -> automatic license issuance) ---
# Enables /buy in the bot (Telegram Stars) and POST /billing/webhook.
BILLING_ENABLED=false
# Price in Telegram Stars (XTR).
BILLING_PRICE_STARS=2500
BILLING_PLAN=standard
# License validity in days (0 = perpetual).
BILLING_PLAN_DAYS=365
# HMAC-SHA256 secret for the external-payments webhook (empty = disabled).
BILLING_WEBHOOK_SECRET=

# --- Plans / tiers (Free / Plus / Pro) ---
# Daily message allowance per tier (0 = unlimited). Free is intentionally tight,
# Plus is generous, Pro is unlimited. Limits apply only when AUTH + BILLING are on.
PLAN_FREE_DAILY=10
PLAN_PLUS_DAILY=100
PLAN_PRO_DAILY=0
# Telegram Stars prices shown on the Plus / Pro upgrade cards.
PLAN_PLUS_PRICE_STARS=2500
PLAN_PRO_PRICE_STARS=8000

# --- Image generation (Plus/Pro feature) ---
# Enable the bot's 🎨 image mode. Needs an OpenAI-compatible Images API key;
# IMAGE_API_KEY / IMAGE_BASE_URL fall back to the OPENAI_* ones when blank.
IMAGE_ENABLED=false
IMAGE_MODEL=dall-e-3
IMAGE_SIZE=1024x1024
IMAGE_API_KEY=
IMAGE_BASE_URL=

# --- Web / AI search (Search Manager) ---
# The AI never hits the internet directly — it goes through the Search Manager,
# which routes to the first available provider (AI-search first, DuckDuckGo is a
# free, keyless fallback). Add a key to enable that provider.
SEARCH_ENABLED=true
SEARCH_PROVIDER=auto           # auto | tavily | exa | brave | google | serpapi | duckduckgo
TAVILY_API_KEY=
EXA_API_KEY=
BRAVE_API_KEY=
PERPLEXITY_API_KEY=
SERPAPI_KEY=
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=

# --- Referrals ---
# Extra daily messages granted to a user for each friend they invite (0 keeps
# invite links working but grants no bonus).
REFERRAL_BONUS_DAILY=20

# --- Proactive messaging (the bot reaches out first; users opt in per-user) ---
# Hour (server local time, 0-23) for the opt-in morning check-in.
PROACTIVE_MORNING_HOUR=9
# Gently nudge users quiet for at least this many days (0 disables nudges).
PROACTIVE_IDLE_DAYS=3

# --- Telegram bot ---
# Get a token from @BotFather. Never commit your real token — keep it here in
# your local .env only.
TELEGRAM_BOT_TOKEN=
# Optional: restrict access to specific Telegram user IDs (comma-separated).
# Leave empty to allow everyone.
TELEGRAM_ALLOWED_USERS=
# Telegram user IDs with access to the bot's owner admin panel (/admin).
# Find your ID via @userinfobot. Comma-separated.
TELEGRAM_ADMIN_USERS=
# VIP user IDs — always Pro (unlimited, all features), no licence/key needed.
# Great for close people: hand them a bot that's ready to use out of the box.
TELEGRAM_VIP_USERS=
# Allow the assistant to SEND Telegram messages/posts as a tool (outbound).
TELEGRAM_SEND_ENABLED=false
# Default channel (@channelusername or chat id) for the telegram_post tool.
TELEGRAM_CHANNEL=
# Require users to join this channel before using the bot (empty = no gate).
# The bot must be an admin of the channel to check membership.
TELEGRAM_REQUIRED_CHANNEL=
